{
  "manifest_version": 3,
  "name": "XApi HTTP Client - Api Testing Tool, Modify Response",
  "version": "3.1.3",
  "description": "Intercept, debug, modify response & replay HTTP requests. A comprehensive API client and cURL support inside Chrome DevTools.",
  "default_locale": "en",
  "permissions": [
    "storage",
    "contextMenus",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["mock-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["mock-injector.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "devtools_page": "devtools.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "XApi HTTP Client",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
